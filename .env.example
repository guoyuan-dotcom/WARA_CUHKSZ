# Copy this file to .env for local development.
# Never commit real API keys. Keep values empty in the release package.

# Default model profile
WARA_MODEL_PROFILE=kimi-k2.6-no-thinking

# Cost display
# Kimi prices published in CNY are converted to USD for the web console.
WARA_CNY_PER_USD=7.25

# OpenAI interface
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Kimi interface
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# DeepSeek interface
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Optional literature-search interfaces
IEEE_XPLORE_API_KEY=
IEEE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Optional execution controls
WARA_PYTHON=
WARA_PHASE1_LITERATURE_SEARCH=1
WARA_PHASE1_ENABLE_IEEE_XPLORE=0
WARA_PHASE1_ENABLE_OPENALEX=0
WARA_PHASE1_ENABLE_SEMANTIC_SCHOLAR=1
WARA_PHASE1_GOOGLE_SCHOLAR=0
WARA_PHASE1_JSON_REPAIR_ROUNDS=3
WARA_PHASE2_CONTRACT_REPAIR_ROUNDS=3
WARA_PHASE24_REPAIR_ROUNDS=10
WARA_PHASE24_DESIGN_REPAIR_ROUNDS=10
WARA_PHASE24_VALIDATION_TIMEOUT_SEC=900
WARA_PHASE25_AUTO_PAPER_RUNS=10
WARA_PHASE25_REDESIGN_ROUNDS=10
WARA_PHASE25_COVERAGE_EXTENSION_ROUNDS=10
WARA_PHASE25_IMPL_REPAIR_ROUNDS=10
WARA_PHASE25_IMPL_REPAIR_ATTEMPTS=10
WARA_PHASE3_1_WRITING_REPAIR_ROUNDS=3
WARA_PHASE32_TECHNICAL_REPAIR_ROUNDS=3
WARA_PHASE33_PUBLIC_SUMMARY_REPAIR_ROUNDS=3
WARA_MAX_REVIEW_REPAIR_ROUNDS=3
WARA_PHASE3_TO_PHASE2_ROUTE_ROUNDS=0
